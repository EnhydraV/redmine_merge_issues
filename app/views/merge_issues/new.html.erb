<%# app/views/merge_issues/new.html.erb %>
<%# Rendered inside a <dialog> / modal triggered from the issue page %>

<div id="merge-modal-overlay" class="merge-modal-overlay" role="dialog" aria-modal="true"
     aria-labelledby="merge-modal-title">

  <div class="merge-modal-box">

    <button class="merge-modal-close" onclick="closeMergeModal()" aria-label="<%= l(:button_close) %>">&#x2715;</button>

    <div class="merge-modal-header">
      <span class="merge-modal-icon">&#x2299;</span>
      <h2 id="merge-modal-title"><%= l(:label_merge_issue) %></h2>
      <p class="merge-modal-subtitle">
        <%= l(:label_merge_source_info, id: @issue.id, subject: h(@issue.subject)) %>
      </p>
    </div>

    <% if flash[:error].present? %>
      <div class="merge-flash-error"><%= flash[:error] %></div>
    <% end %>

    <%= form_tag(issue_merge_path(@issue), method: :post, id: 'merge-form') do %>

      <div class="merge-field-group">
        <label for="destination_issue_id" class="merge-label">
          <%= l(:label_merge_destination_issue) %>
          <span class="merge-required" aria-hidden="true">*</span>
        </label>
        <div class="merge-input-wrapper">
          <span class="merge-input-prefix">#</span>
          <%= text_field_tag :destination_issue_id, '',
              id: 'destination_issue_id',
              class: 'merge-input',
              placeholder: l(:placeholder_merge_issue_id),
              autocomplete: 'off',
              required: true,
              pattern: '[0-9]+',
              'aria-describedby' => 'merge-input-hint' %>
        </div>
        <p id="merge-input-hint" class="merge-hint"><%= l(:hint_merge_destination) %></p>
        <div id="merge-preview" class="merge-preview" aria-live="polite"></div>
      </div>

      <div class="merge-warning">
        <span class="merge-warning-icon">&#9888;</span>
        <p><%= l(:warning_merge_irreversible) %></p>
      </div>

      <div class="merge-actions">
        <button type="button" class="merge-btn merge-btn-cancel" onclick="closeMergeModal()">
          <%= l(:button_cancel) %>
        </button>
        <%= submit_tag l(:button_merge), class: 'merge-btn merge-btn-confirm',
            id: 'merge-submit-btn', disabled: true %>
      </div>

    <% end %>
  </div>
</div>

<style>
/* ================================================================
   Merge Tickets Modal — scoped styles
   ================================================================ */
.merge-modal-overlay {
  position: fixed;
  inset: 0;
  background: rgba(10, 15, 30, 0.72);
  backdrop-filter: blur(4px);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
  padding: 1rem;
  animation: mergeOverlayIn 0.18s ease;
}
@keyframes mergeOverlayIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}

.merge-modal-box {
  position: relative;
  background: #fff;
  border-radius: 12px;
  padding: 2rem 2.25rem 1.75rem;
  width: 100%;
  max-width: 480px;
  box-shadow: 0 24px 64px rgba(0,0,0,0.22), 0 4px 16px rgba(0,0,0,0.1);
  animation: mergeBoxIn 0.22s cubic-bezier(0.34, 1.56, 0.64, 1);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}
@keyframes mergeBoxIn {
  from { opacity: 0; transform: scale(0.92) translateY(8px); }
  to   { opacity: 1; transform: scale(1)    translateY(0);   }
}

.merge-modal-close {
  position: absolute;
  top: 1rem;
  right: 1rem;
  background: none;
  border: none;
  font-size: 1.1rem;
  color: #6b7280;
  cursor: pointer;
  width: 28px; height: 28px;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  transition: background 0.15s, color 0.15s;
  line-height: 1;
  padding: 0;
}
.merge-modal-close:hover { background: #f3f4f6; color: #111; }

.merge-modal-header { margin-bottom: 1.5rem; }
.merge-modal-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 40px; height: 40px;
  background: #eef2ff;
  border-radius: 10px;
  font-size: 1.3rem;
  margin-bottom: 0.75rem;
  color: #4f46e5;
}
.merge-modal-header h2 {
  margin: 0 0 0.35rem;
  font-size: 1.25rem;
  font-weight: 700;
  color: #111827;
  letter-spacing: -0.02em;
}
.merge-modal-subtitle {
  margin: 0;
  font-size: 0.88rem;
  color: #6b7280;
}
.merge-modal-subtitle strong { color: #374151; }

/* Flash */
.merge-flash-error {
  background: #fef2f2;
  border: 1px solid #fecaca;
  color: #b91c1c;
  border-radius: 8px;
  padding: 0.6rem 0.9rem;
  font-size: 0.875rem;
  margin-bottom: 1.25rem;
}

/* Field */
.merge-field-group { margin-bottom: 1.1rem; }
.merge-label {
  display: block;
  font-size: 0.875rem;
  font-weight: 600;
  color: #374151;
  margin-bottom: 0.5rem;
}
.merge-required { color: #ef4444; margin-left: 2px; }
.merge-input-wrapper {
  display: flex;
  align-items: center;
  border: 1.5px solid #d1d5db;
  border-radius: 8px;
  overflow: hidden;
  transition: border-color 0.15s, box-shadow 0.15s;
  background: #fff;
}
.merge-input-wrapper:focus-within {
  border-color: #6366f1;
  box-shadow: 0 0 0 3px rgba(99,102,241,0.15);
}
.merge-input-prefix {
  padding: 0 0 0 0.85rem;
  color: #9ca3af;
  font-size: 1rem;
  font-weight: 500;
  user-select: none;
}
.merge-input {
  flex: 1;
  border: none !important;
  outline: none !important;
  padding: 0.6rem 0.75rem 0.6rem 0.25rem !important;
  font-size: 1rem;
  color: #111827;
  background: transparent !important;
  box-shadow: none !important;
}
.merge-hint {
  margin: 0.35rem 0 0;
  font-size: 0.8rem;
  color: #9ca3af;
}

/* Live preview */
.merge-preview {
  margin-top: 0.6rem;
  min-height: 0;
  font-size: 0.85rem;
  transition: all 0.2s;
}
.merge-preview.loading { color: #6b7280; font-style: italic; }
.merge-preview.found {
  background: #f0fdf4;
  border: 1px solid #bbf7d0;
  border-radius: 8px;
  padding: 0.5rem 0.75rem;
  color: #166534;
}
.merge-preview.found strong { color: #14532d; }
.merge-preview.not-found {
  background: #fef2f2;
  border: 1px solid #fecaca;
  border-radius: 8px;
  padding: 0.5rem 0.75rem;
  color: #b91c1c;
}

/* Warning */
.merge-warning {
  display: flex;
  gap: 0.6rem;
  align-items: flex-start;
  background: #fffbeb;
  border: 1px solid #fde68a;
  border-radius: 8px;
  padding: 0.7rem 0.9rem;
  margin-bottom: 1.5rem;
}
.merge-warning-icon { font-size: 0.95rem; flex-shrink: 0; margin-top: 1px; }
.merge-warning p { margin: 0; font-size: 0.83rem; color: #78350f; line-height: 1.45; }

/* Buttons */
.merge-actions { display: flex; gap: 0.6rem; justify-content: flex-end; }
.merge-btn {
  padding: 0.55rem 1.2rem;
  border-radius: 8px;
  font-size: 0.875rem;
  font-weight: 600;
  cursor: pointer;
  border: none;
  transition: background 0.15s, transform 0.1s, box-shadow 0.15s;
}
.merge-btn:active { transform: scale(0.97); }

.merge-btn-cancel {
  background: #f3f4f6;
  color: #374151;
}
.merge-btn-cancel:hover { background: #e5e7eb; }

.merge-btn-confirm {
  background: #4f46e5;
  color: #fff;
  box-shadow: 0 2px 8px rgba(79,70,229,0.3);
}
.merge-btn-confirm:hover:not(:disabled) {
  background: #4338ca;
  box-shadow: 0 4px 12px rgba(79,70,229,0.4);
}
.merge-btn-confirm:disabled {
  background: #c7d2fe;
  cursor: not-allowed;
  box-shadow: none;
}
</style>

<script>
(function () {
  var debounceTimer;
  var currentSourceId = <%= @issue.id %>;

  function closeMergeModal() {
    var overlay = document.getElementById('merge-modal-overlay');
    if (overlay) overlay.remove();
  }

  // Close on overlay click
  document.getElementById('merge-modal-overlay').addEventListener('click', function (e) {
    if (e.target === this) closeMergeModal();
  });

  // Close on Escape
  document.addEventListener('keydown', function handler(e) {
    if (e.key === 'Escape') { closeMergeModal(); document.removeEventListener('keydown', handler); }
  });

  // Live preview: fetch issue title via Redmine JSON API
  var input   = document.getElementById('destination_issue_id');
  var preview = document.getElementById('merge-preview');
  var submit  = document.getElementById('merge-submit-btn');

  input.addEventListener('input', function () {
    clearTimeout(debounceTimer);
    var val = this.value.replace(/\D/g, '');
    submit.disabled = true;
    preview.className = 'merge-preview';
    preview.innerHTML = '';

    if (!val || val.length === 0) return;

    var id = parseInt(val, 10);
    if (id === currentSourceId) {
      preview.className = 'merge-preview not-found';
      preview.textContent = '<%= j l(:error_merge_same_issue) %>';
      return;
    }

    preview.className = 'merge-preview loading';
    preview.textContent = '<%= j l(:label_merge_checking) %>';

    debounceTimer = setTimeout(function () {
      fetch('<%= root_path %>issues/' + id + '.json', {
        headers: { 'X-Requested-With': 'XMLHttpRequest' }
      })
      .then(function (r) {
        if (!r.ok) throw new Error('not found');
        return r.json();
      })
      .then(function (data) {
        var issue = data.issue;
        preview.className = 'merge-preview found';
        preview.innerHTML =
          '&#10003; <strong>#' + issue.id + '</strong> &mdash; ' + escHtml(issue.subject) +
          ' <span style="color:#6b7280">(' + escHtml(issue.project.name) + ')</span>';
        submit.disabled = false;
        // Update the input to show just the id
        input.value = issue.id;
      })
      .catch(function () {
        preview.className = 'merge-preview not-found';
        preview.textContent = '<%= j l(:error_merge_destination_not_found) %>';
        submit.disabled = true;
      });
    }, 400);
  });

  function escHtml(str) {
    return String(str)
      .replace(/&/g,'&amp;').replace(/</g,'&lt;')
      .replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  // Make closeMergeModal global
  window.closeMergeModal = closeMergeModal;
})();
</script>
